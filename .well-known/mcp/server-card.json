    },
    {
      "name": "owasp_check",
      "description": "Check endpoint against OWASP Top 10 2021."
    },
    {
      "name": "scan_owasp_2021",
      "description": "Full OWASP Top 10 2021 vulnerability scanner."
    }
  ],
  "categories": [
    "AI & Machine Learning",
    "Security & Compliance"
  ],
  "pricing": {
    "free": {
      "calls_per_day": 15
    },
    "pro": {
      "price": "$29/month",
