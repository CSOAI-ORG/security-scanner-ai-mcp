{
  "name": "security-scanner-ai",
  "description": "MEOK AI Labs \u2014 Security scanning. OWASP Top 10, dependency scanning, secret detection, HTTP header analysis.",
  "version": "1.0.0",
  "protocol_version": "2025-11-25",
  "publisher": {
    "name": "MEOK AI Labs",
    "url": "https://meok.ai",
    "email": "nicholas@meok.ai"
  },
  "repository": "https://github.com/CSOAI-ORG/security-scanner-ai-mcp",
  "license": "MIT",
  "transport": [
    "stdio",
    "streamable-http"
  ],
  "authentication": {
    "type": "api-key",
    "free_tier": true,
    "free_limit": "15 calls/day"
  },
  "tools": [
    {
      "name": "scan_dependencies",
      "description": "Scan requirements.txt for vulnerable dependencies."
    },
    {
